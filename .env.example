# Шаблон переменных окружения.
# Скопируй в .env и подставь свои значения. Файл .env НЕ коммитится (см. .gitignore).

BASE_URL=https://example.com
LOGIN=your_login_here
PASSWORD=your_password_here

# Для UI-теста логина github.com (позитивный поток).
# Без них позитивный тест скипается. Реальные креды — только в .env, не сюда!
GH_USER=your_github_login
GH_PASS=your_github_password
